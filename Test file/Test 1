        this.statorRings = [];
        const statorMaterial = this.materials.darkMetal;
        [[-3.55, 1.52],[ -2.3, 1.45], [0.2, 1.32], [1.82, 1.08], [3.0, 0.98], [4.92, 1.1]].forEach(([x, r], index) => {
          const ring = new THREE.Mesh(new THREE.TorusGeometry(r, 0.03, 10, 42), statorMaterial);
          ring.rotation.x = Math.PI / 2;
          ring.position.x = x;
          ring.userData.key = index < 2 ? 'lpc' : index < 4 ? 'hpc' : index < 5 ? 'hpt' : 'lpt';
          this.group.add(ring);
          this.statorRings.push(ring);
        });

        // Labels / callouts anchor points.
        this.calloutAnchors = [
          { key: 'fan', pos: new THREE.Vector3(-4.6, 2.7, 0.0) },
          { key: 'lpc', pos: new THREE.Vector3(-2.9, 2.0, 0.0) },
          { key: 'hpc', pos: new THREE.Vector3(-0.7, 2.1, 0.0) },
          { key: 'combustor', pos: new THREE.Vector3(1.1, 2.0, 0.0) },
          { key: 'hpt', pos: new THREE.Vector3(2.7, 1.9, 0.0) },
          { key: 'lpt', pos: new THREE.Vector3(4.3, 2.0, 0.0) },
          { key: 'nozzle', pos: new THREE.Vector3(5.7, 1.8, 0.0) }
        ];

        // Additional rotor discs.
        this.rotorDiscs = [];
        for (const [x, radius, key] of [[-4.5, 1.18, 'fan'], [-2.9, 0.85, 'lpc'], [-0.8, 0.72, 'hpc'], [2.65, 0.6, 'hpt'], [4.2, 0.8, 'lpt']]) {
          const disc = new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 0.12, 24), this.materials.darkMetal);
          disc.rotation.z = Math.PI / 2;
          disc.position.x = x;
          disc.userData.key = key;
          this.group.add(disc);
          this.rotorDiscs.push(disc);
        }

        // A faint engine frame helps soldify engineering presentation look.
        const frame = new THREE.Mesh(new THREE.BoxGeometry(13.4, 0.08, 0.08), new THREE.MeshStandardMaterial({ color: 0x708090, metalness: 0.8, roughness: 0.45 }));
        frame.position.set(0, -1.62, 0);
        this.group.add(frame);
        const frame2 = frame.clone(); frame2.position.y = 1.62; this.group.add(frame2);
      }

      setCutaway(v) {
        this.cutawayAmount = v;
        const side = 0.06 + v * 0.88;
        this.leftShell.scale.z = side;
        this.rightShell.scale.z = side;
        this.leftShell.material.opacity = 0.06 + v * 0.18;
        this.rightShell.material.opacity = 0.06 + v * 0.18;
        if (this.flame) this.flame.material.opacity = 0.15 + v * 0.85;
      }

      setExploded(v) {
        this.explodedAmount = v;
        const spacing = 1 + v * 1.0;
        this.parts.fan.position.x = -4.5 - v * 0.6;
        this.parts.spinner.position.x = -5.1 - v * 0.5;
        this.parts.fanHub.position.x = -4.5 - v * 0.55;
        this.parts.fanShaft.position.x = -1.8 + v * 0.14;
        this.parts.coreShaft.position.x = 0.0 + v * 0.08;
        this.parts.nacelle.position.x = 0;
        this.parts.nozzleOuter.position.x = 5.55 + v * 0.5;
        this.parts.nozzleLip.position.x = 6.25 + v * 0.6;
        this.parts.combustorShell.position.x = 1.1 + v * 0.08;
        this.parts.combustorGlow.position.x = 1.1 + v * 0.08;
        this.parts.combustorCore.position.x = 1.15 + v * 0.08;
        this.parts.hpt.position.x = 2.65 + v * 0.18;
        this.parts.hptRing.position.x = 2.65 + v * 0.18;
        this.parts.lpt.position.x = 4.2 + v * 0.3;
        this.parts.lptRing.position.x = 4.2 + v * 0.3;
        this.injectors.position.x = 0.0 + v * 0.08;
        this.flame.position.x = 1.18 + v * 0.08;
        this.hotGasCore.position.x = 3.4 + v * 0.2;
        this.statorRings.forEach((ring, idx) => {
          const dir = idx < 2 ? -1 : idx < 4 ? 0 : 1;
          ring.position.x += dir * v * (0.12 + idx * 0.02);
        });
        this.rotorDiscs.forEach((disc, idx) => {
          const base = [-4.5, -2.9, -0.8, 2.65, 4.2][idx];
          disc.position.x = base + (idx * 0.1 - 0.2) * v;
        });
      }

      resetPositions() {
        this.setExploded(0);
        this.setCutaway(0.52);
      }

      update(dt, rpmTarget) {
        this.time += dt;
        const target = THREE.MathUtils.clamp(rpmTarget / 100, 0, 1);
        const easing = STATE.engineOn ? 0.025 : 0.03;
        this.rpm = THREE.MathUtils.lerp(this.rpm, target * 100, easing);
        this.n1 = THREE.MathUtils.lerp(this.n1, this.rpm * 0.95, 0.03);
        this.n2 = THREE.MathUtils.lerp(this.n2, this.rpm * 1.18, 0.04);
        this.pressure = THREE.MathUtils.lerp(this.pressure, 1 + target * 30, 0.02);
        this.temperature = THREE.MathUtils.lerp(this.temperature, 288 + target * 820, 0.018);
        this.egt = THREE.MathUtils.lerp(this.egt, 288 + target * 950, 0.02);
        this.thrust = THREE.MathUtils.lerp(this.thrust, target * 245, 0.018);
        this.fuelFlow = THREE.MathUtils.lerp(this.fuelFlow, target * 2.4, 0.025);
        this.oilPressure = THREE.MathUtils.lerp(this.oilPressure, 2.1 + target * 1.2, 0.02);
        this.oilTemp = THREE.MathUtils.lerp(this.oilTemp, 322 + target * 55, 0.02);
        this.vibration = THREE.MathUtils.lerp(this.vibration, 0.01 + target * 0.32, 0.02);
        this.fuelPhase += dt * (0.22 + target * 2.6);
        this.exhaustPhase += dt * (0.8 + target * 6.6);

        // Material reaction based on power.
        const glow = Math.pow(target, 1.55);
        this.flame.material.emissiveIntensity = 0.2 + glow * 2.8;
        this.flame.material.opacity = 0.06 + glow * 0.95;
        this.combustorGlow.material.emissiveIntensity = 1.0 + glow * 2.8;
        this.hotGasCore.material.opacity = 0.05 + glow * 0.6;
        this.parts.nozzleLip.material.emissiveIntensity = 0.2 + glow * 1.8;

        // Rotation speeds: fan, low pressure spool, high pressure spool, rear turbine.
        const fanSpeed = (0.1 + target * 16);
        const lpcSpeed = (0.2 + target * 28);
        const hpcSpeed = (0.3 + target * 44);
        const hptSpeed = (0.5 + target * 54);
        const lptSpeed = (0.25 + target * 34);

        this.parts.fan.rotation.x += dt * fanSpeed;
        this.parts.fanHub.rotation.x += dt * fanSpeed;
        this.parts.spinner.rotation.x += dt * fanSpeed * 0.96;
        this.parts.fanShaft.rotation.x += dt * fanSpeed * 0.85;
        this.parts.coreShaft.rotation.x += dt * hpcSpeed * 0.78;
        this.parts.bearing1.rotation.x += dt * fanSpeed * 0.82;
        this.parts.bearing2.rotation.x += dt * hpcSpeed * 0.68;
        this.parts.lpc.rotation.x += dt * lpcSpeed;
        this.parts.hpc.rotation.x += dt * hpcSpeed;
        this.parts.hpt.rotation.x += dt * hptSpeed;
        this.parts.lpt.rotation.x += dt * lptSpeed;
        this.parts.hptRing.rotation.x += dt * hptSpeed * 0.06;
        this.parts.lptRing.rotation.x += dt * lptSpeed * 0.06;

        // Slight oscillation for turbine motion and active vibration.
        const vib = Math.sin(this.time * 22) * 0.002 * target;
        this.group.position.y = vib;

        // Update global camera and lighting cues from internal state.
        return {
          rpm: this.rpm,
          n1: this.n1,
          n2: this.n2,
          temperature: this.temperature,
          pressure: this.pressure,
          thrust: this.thrust,
          egt: this.egt,
          vibration: this.vibration,
          fuelFlow: this.fuelFlow,
          oilPressure: this.oilPressure,
          oilTemp: this.oilTemp,
          glow,
          target
        };
      }
    }

    class SceneController {
      constructor() {
        this.renderer = null;
        this.scene = null;
        this.camera = null;
        this.controls = null;
        this.composer = null;
        this.clock = new THREE.Clock();
        this.engine = null;
        this.audio = new AudioEngine();
        this.hotspots = null;
        this.fans = [];
        this.dust = null;
        this.fuelParticles = null;
        this.exhaustParticles = null;
        this.confetti = null;
        this.rays = [];
        this.autoCameraT = 0;
        this.autoCameraEnabled = false;
        this.helpShown = false;
        this.settingsShown = false;
        this._initThree();
        this._buildScene();
        this._bindEvents();
        this._loop();
      }

      _initThree() {
        this.renderer = new THREE.WebGLRenderer({ canvas: UI.threeCanvas, antialias: true, alpha: true, powerPreference: 'high-performance' });
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.renderer.outputColorSpace = THREE.SRGBColorSpace;
        this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
        this.renderer.toneMappingExposure = 1.18;
        this.renderer.shadowMap.enabled = true;
        this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;

        this.scene = new THREE.Scene();
        this.scene.fog = new THREE.FogExp2(0x06070b, 0.038);

        this.camera = new THREE.PerspectiveCamera(42, window.innerWidth / window.innerHeight, 0.1, 120);
        this.camera.position.set(0, 2.3, 14.4);

        this.controls = new OrbitControls(this.camera, UI.threeCanvas);
        this.controls.enableDamping = true;
        this.controls.dampingFactor = 0.08;
        this.controls.minDistance = 7.5;
        this.controls.maxDistance = 26;
        this.controls.enablePan = true;
        this.controls.target.set(0, 0.3, 0);
        this.controls.update();

        const env = new RoomEnvironment();
        const pmrem = new THREE.PMREMGenerator(this.renderer);
        this.scene.environment = pmrem.fromScene(env, 0.04).texture;
        this.scene.background = new THREE.Color(0x04070b);
        pmrem.dispose();
      }

      _buildScene() {
        // Lighting.
        const amb = new THREE.AmbientLight(0xaab9ff, 0.3);
        this.scene.add(amb);
        const hemi = new THREE.HemisphereLight(0x8fd9ff, 0x05070a, 0.42);
        this.scene.add(hemi);
        const dir = new THREE.DirectionalLight(0xffffff, 1.85);
        dir.position.set(-8, 8, 8);
        dir.castShadow = true;
        dir.shadow.mapSize.set(2048, 2048);
        dir.shadow.camera.left = -16;
        dir.shadow.camera.right = 16;
        dir.shadow.camera.top = 16;
        dir.shadow.camera.bottom = -16;
        dir.shadow.camera.near = 0.5;
        dir.shadow.camera.far = 40;
        this.scene.add(dir);
        const rim = new THREE.DirectionalLight(0x85dbff, 1.15);
        rim.position.set(7, 2, -8);
        this.scene.add(rim);
        const blueFill = new THREE.PointLight(0x60dfff, 1.4, 30, 1.75);
        blueFill.position.set(0, 2, 7);
        this.scene.add(blueFill);
        const warm = new THREE.PointLight(0xff9a4a, 0.85, 18, 1.9);
        warm.position.set(1.2, 0, 2.2);
        this.scene.add(warm);
        this.rays.push(dir, rim, blueFill, warm);

        // Ground / platform.
        const floor = new THREE.Mesh(
          new THREE.CircleGeometry(28, 64),
          new THREE.MeshStandardMaterial({ color: 0x0b1016, metalness: 0.55, roughness: 0.88, envMapIntensity: 0.65 })
        );
        floor.rotation.x = -Math.PI / 2;
        floor.position.y = -2.4;
        floor.receiveShadow = true;
        this.scene.add(floor);

        const platformRing = new THREE.Mesh(
          new THREE.TorusGeometry(9.4, 0.08, 12, 120),
          new THREE.MeshStandardMaterial({ color: 0x24303d, metalness: 0.75, roughness: 0.38 })
        );
        platformRing.rotation.x = Math.PI / 2;
        platformRing.position.y = -2.39;
        this.scene.add(platformRing);

        // Engine.
        this.engine = new EngineSimulation(this.scene);
        this.engine.group.castShadow = true;
        this.engine.group.receiveShadow = true;
        this.engine.setCutaway(0.52);
        this.engine.resetPositions();

        // Particle systems.
        this.dust = new ParticleField(this.scene, 1200, 'dust');
        this.fuelParticles = new ParticleField(this.scene, 240, 'fuel');
        this.exhaustParticles = new ParticleField(this.scene, 320, 'exhaust');
        this.confetti = new ParticleField(this.scene, 320, 'confetti');
        this.confetti.points.material.size = 0.08;
        this.confetti.points.visible = false;

        // HUD hotspots.
        this.hotspots = new HotspotManager(
          this.scene,
          this.camera,
          UI.threeCanvas,
          (spot, x, y) => this._showTooltip(spot, x, y),
          (spot) => this._selectComponent(spot)
        );
        for (const [meshKey, key, label] of [
          ['fan', 'fan', 'Fan'],
          ['lpc', 'lpc', 'Low Pressure Compressor'],
          ['hpc', 'hpc', 'High Pressure Compressor'],
          ['combustor', 'combustor', 'Combustion Chamber'],
          ['hpt', 'hpt', 'High Pressure Turbine'],
          ['lpt', 'lpt', 'Low Pressure Turbine'],
          ['nozzle', 'nozzle', 'Nozzle'],
          ['nacelle', 'nacelle', 'Outer Nacelle'],
          ['shaft', 'shaft', 'Shaft']
        ]) {
          const mesh = this.engine.parts[meshKey] || this.engine[meshKey] || this.engine.parts[meshKey + 'Ring'] || this.engine.parts[meshKey + 'Core'];
          if (mesh) this.hotspots.add(mesh, key, label);
        }
        // Add more precise parts for robust selection.
        this.hotspots.add(this.engine.parts.fanHub, 'fan', 'Fan Hub');
        this.hotspots.add(this.engine.parts.spinner, 'fan', 'Spinner Cone');
        this.hotspots.add(this.engine.parts.nozzleLip, 'nozzle', 'Exhaust Lip');
        this.hotspots.add(this.engine.parts.combustorShell, 'combustor', 'Combustor Shell');
        this.hotspots.add(this.engine.parts.combustorGlow, 'combustor', 'Hot Liner');
        this.hotspots.add(this.engine.parts.coreShaft, 'shaft', 'Core Shaft');
        this.hotspots.add(this.engine.parts.fanShaft, 'shaft', 'Fan Shaft');

        // Post processing.
        this.composer = new EffectComposer(this.renderer);
        const renderPass = new RenderPass(this.scene, this.camera);
        this.composer.addPass(renderPass);
        this.bloom = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 0.85, 0.55, 0.18);
        this.composer.addPass(this.bloom);
        this.composer.addPass(new SMAAPass(window.innerWidth * this.renderer.getPixelRatio(), window.innerHeight * this.renderer.getPixelRatio()));
        const copy = new ShaderPass(CopyShader);
        copy.renderToScreen = true;
        this.composer.addPass(copy);

        // Decorative hangar lights behind engine.
        this.hangarBeams = [];
        for (let i = 0; i < 6; i++) {
          const beam = new THREE.Mesh(
            new THREE.PlaneGeometry(16, 0.45),
            new THREE.MeshBasicMaterial({ color: 0x79dbff, transparent: true, opacity: 0.08, side: THREE.DoubleSide, blending: THREE.AdditiveBlending })
          );
          beam.position.set(-4 + i * 2.0, 4.5 + (i % 2) * 0.5, -5.5 + i * 0.5);
          beam.rotation.z = -0.25 + i * 0.08;
          this.scene.add(beam);
          this.hangarBeams.push(beam);
        }
      }

      _bindEvents() {
        window.addEventListener('resize', () => this._onResize());
        window.addEventListener('dblclick', () => this._resetCamera());
        UI.startBtn.addEventListener('click', () => this._enterSimulation());
        UI.btnStartEngine.addEventListener('click', () => this._startEngine());
        UI.btnStopEngine.addEventListener('click', () => this._stopEngine());
        UI.btnDiagnostics.addEventListener('click', () => this._runDiagnostics());
        UI.btnReset.addEventListener('click', () => this._resetAll());
        UI.btnAutoCamera.addEventListener('click', () => this._toggleAutoCamera());
        UI.btnExploded.addEventListener('click', () => this._toggleExploded());
        UI.btnCutaway.addEventListener('click', () => this._toggleCutaway());
        UI.btnFullscreen.addEventListener('click', () => this._fullscreen());
        UI.btnHelp.addEventListener('click', () => this._showHelp());
        UI.btnHelp2.addEventListener('click', () => this._showHelp());
        UI.btnSettings.addEventListener('click', () => this._showSettings());
        UI.btnSettings2.addEventListener('click', () => this._showSettings());
        UI.btnDialogClose.addEventListener('click', () => UI.dialogPanel.classList.remove('show'));
        UI.btnDiagClose.addEventListener('click', () => this._endDiagnostics(true));
        UI.rpmSlider.addEventListener('input', (e) => {
          if (STATE.diagnostics) return;
          STATE.rpmTarget = Number(e.target.value);
          UI.rpmPercent.textContent = `${STATE.rpmTarget}%`;
          STATE.engineOn = STATE.rpmTarget > 0;
          this.audio.resume();
          this.audio.click();
        });

        // Better pointer feedback for the start screen.
        document.addEventListener('pointerdown', () => this.audio.resume(), { once: true });
      }

      _enterSimulation() {
        this.audio.init();
        this.audio.resume();
        STATE.started = true;
        UI.welcomeScreen.classList.remove('active');
        UI.mainScreen.classList.add('active');
        gsap.fromTo(UI.mainScreen, { opacity: 0 }, { opacity: 1, duration: 0.6, ease: 'power2.out' });
        this._startEngine();
        this._resetCamera();
      }

      _startEngine() {
        this.audio.init();
        this.audio.resume();
        STATE.engineOn = true;
        if (STATE.rpmTarget < 18) STATE.rpmTarget = 18;
        UI.rpmSlider.value = STATE.rpmTarget;
        UI.rpmPercent.textContent = `${STATE.rpmTarget}%`;
        UI.engineStatus.textContent = 'SPINNING';
        UI.engineStatus.parentElement.className = 'status-pill ok';
        UI.ignitionState.textContent = 'ON';
        this.audio.ignition();
        STATE.alarm = false;
      }

      _stopEngine() {
        STATE.rpmTarget = 0;
        UI.rpmSlider.value = 0;
        UI.rpmPercent.textContent = '0%';
        UI.engineStatus.textContent = 'COAST DOWN';
        UI.engineStatus.parentElement.className = 'status-pill warn';
        UI.ignitionState.textContent = 'OFF';
        STATE.engineOn = false;
        this.audio.click();
      }

      _resetAll() {
        this._stopEngine();
        STATE.time = 0;
        STATE.alarm = false;
        STATE.diagnostics = false;
        STATE.diagRunning = false;
        STATE.diagStep = 0;
        STATE.cutaway = true;
        STATE.exploded = false;
        STATE.autoCamera = false;
        STATE.cameraPulse = 0;
        STATE.selectedComponent = null;
        STATE.hoveredComponent = null;
        UI.diagPanel.classList.remove('show');
        UI.dialogPanel.classList.remove('show');
        this.engine.resetPositions();
        this.engine.setCutaway(0.52);
        this.audio.click();
        this._populateComponentCard(null);
        this._resetCamera();
      }

      _toggleAutoCamera() {
        STATE.autoCamera = !STATE.autoCamera;
        this.autoCameraEnabled = STATE.autoCamera;
        UI.btnAutoCamera.classList.toggle('primary', STATE.autoCamera);
        this.audio.click();
      }

      _toggleExploded() {
        STATE.exploded = !STATE.exploded;
        this.audio.click();
        gsap.to(this.engine, { duration: 1.0, ease: 'power3.inOut', onUpdate: () => this.engine.setExploded(STATE.exploded ? 1 : 0) });
      }

      _toggleCutaway() {
        STATE.cutaway = !STATE.cutaway;
        this.audio.click();
        gsap.to(this.engine, { duration: 0.9, ease: 'power3.inOut', onUpdate: () => this.engine.setCutaway(STATE.cutaway ? 0.7 : 0.28) });
      }

      _showHelp() {
        UI.dialogTitle.textContent = 'How to Use';
        UI.dialogText.textContent = 'Rotate with the mouse or touch, zoom with the wheel or pinch, pan with right mouse or two-finger drag, double-click to reset, and use the controls to spool the engine, open exploded view, or run the automated diagnostic sequence.';
        UI.dialogPanel.classList.add('show');
        this.audio.click();
      }

      _showSettings() {
        UI.dialogTitle.textContent = 'Settings';
        UI.dialogText.textContent = 'This demonstration is optimized for visual fidelity and smooth interaction. In a production deployment you could add resolution scaling, audio toggles, data export, unit switching, and custom camera presets.';
        UI.dialogPanel.classList.add('show');
        this.audio.click();
      }

      _fullscreen() {
        const el = document.documentElement;
        if (!document.fullscreenElement && el.requestFullscreen) el.requestFullscreen();
        else if (document.exitFullscreen) document.exitFullscreen();
        this.audio.click();
      }

      _selectComponent(spot) {
        const info = COMPONENT_INFO[spot.key];
        if (!info) return;
        STATE.selectedComponent = spot.key;
        this._populateComponentCard(info);
        UI.dialogTitle.textContent = info.title;
        UI.dialogText.textContent = `${info.desc} Function: ${info.function}. Material: ${info.material}. Maintenance notes: ${info.maintenance}. Failure modes: ${info.failure}.`;
        UI.dialogPanel.classList.add('show');
        this.audio.click();
      }

      _populateComponentCard(info) {
        if (!info) {
          UI.componentName.textContent = 'No Selection';
          UI.componentDesc.textContent = 'Select a component or hover over the engine to view engineering information, materials, function, and maintenance notes.';
          UI.componentInfo.innerHTML = `
            <div class="info-row"><span>Function</span><span>—</span></div>
            <div class="info-row"><span>Temperature</span><span>—</span></div>
            <div class="info-row"><span>RPM</span><span>—</span></div>
            <div class="info-row"><span>Pressure</span><span>—</span></div>
            <div class="info-row"><span>Material</span><span>—</span></div>
            <div class="info-row"><span>Maintenance</span><span>—</span></div>`;
          return;
        }
        UI.componentName.textContent = info.title;
        UI.componentDesc.textContent = info.desc;
        UI.componentInfo.innerHTML = `
          <div class="info-row"><span>Function</span><span>${info.function}</span></div>
          <div class="info-row"><span>Temperature</span><span>${info.temperature}</span></div>
          <div class="info-row"><span>RPM</span><span>${info.rpm}</span></div>
          <div class="info-row"><span>Pressure</span><span>${info.pressure}</span></div>
          <div class="info-row"><span>Material</span><span>${info.material}</span></div>
          <div class="info-row"><span>Maintenance</span><span>${info.maintenance}</span></div>`;
      }

      _showTooltip(spot, x, y) {
        const info = COMPONENT_INFO[spot.key];
        if (!info) return;
        UI.tooltipTitle.textContent = info.title;
        UI.tooltipDesc.textContent = info.desc;
        UI.tooltip.style.left = `${Math.min(window.innerWidth - 280, x + 18)}px`;
        UI.tooltip.style.top = `${Math.min(window.innerHeight - 100, y + 18)}px`;
        UI.tooltip.classList.add('show');
        STATE.hoveredComponent = spot.key;
      }

      _resetCamera() {
        gsap.to(this.camera.position, { x: 0, y: 2.3, z: 14.4, duration: 1.1, ease: 'power3.inOut' });
        gsap.to(this.controls.target, { x: 0, y: 0.3, z: 0, duration: 1.1, ease: 'power3.inOut', onUpdate: () => this.controls.update() });
      }

      _runDiagnostics() {
        if (STATE.diagRunning) return;
        STATE.diagRunning = true;
        STATE.diagnostics = true;
        STATE.alarm = false;
        UI.diagPanel.classList.add('show');
        this.hotspots.enabled = false;
        this.controls.enabled = false;
        UI.engineStatus.textContent = 'DIAGNOSTIC';
        UI.engineStatus.parentElement.className = 'status-pill warn';
        UI.diagState.textContent = 'ACTIVE';
        UI.dataMode.textContent = 'DIAGNOSTIC';
        UI.lightEmergency.classList.remove('bad');
        UI.lightEmergency.classList.add('warn');
        this._setChecklist(['PENDING', 'PENDING', 'PENDING', 'PENDING']);
        this.audio.click();
        this.audio.resume();
        this.engine.engineOn = true;
        STATE.rpmTarget = 12;
        UI.rpmSlider.value = 12;
        UI.rpmPercent.textContent = '12%';
        this._diagnosticSequence();
      }

      _setChecklist(statuses) {
        const items = [...document.querySelectorAll('#checklist .check-item')];
        items.forEach((item, i) => {
          item.classList.remove('pass', 'fail');
          const s = item.querySelector('.status');
          s.textContent = statuses[i] || 'PENDING';
          if (statuses[i] === 'PASS' || statuses[i] === 'VERIFIED') item.classList.add('pass');
          if (statuses[i] === 'FAIL') item.classList.add('fail');
        });
      }

      async _diagnosticSequence() {
        const sleep = (ms) => new Promise(r => setTimeout(r, ms));
        const step = async (num, title, sub, progress, listFn) => {
          UI.diagBig.textContent = `STEP ${num}`;
          UI.diagSub.textContent = title;
          UI.diagProgress.style.width = `${progress}%`;
          if (listFn) listFn();
          this.audio.alarmPulse();
          await sleep(900);
        };

        // Step 1: Rotor integrity.
        UI.diagSub.textContent = 'Rotor Integrity Check';
        this._setChecklist(['RUNNING', 'RUNNING', 'RUNNING', 'PENDING']);
        for (let i = 0; i <= 50; i += 5) {
          STATE.rpmTarget = i;
          UI.rpmSlider.value = i;
          UI.rpmPercent.textContent = `${i}%`;
          UI.diagProgress.style.width = `${i}%`;
          await sleep(90);
        }
        this._setChecklist(['PASS', 'PENDING', 'PENDING', 'PENDING']);
        UI.diagSub.textContent = 'Checking Rotor Balance...';
        await sleep(450);
        UI.diagSub.textContent = 'Checking Shaft Alignment...';
        await sleep(450);
        UI.diagSub.textContent = 'Checking Bearing Vibration...';
        await sleep(450);
        this.audio.alarmPulse();
        await step(1, 'Rotor Integrity Check', 'Rotor verification complete', 25);

        // Step 2: Fuel system.
        UI.diagBig.textContent = 'STEP 2';
        UI.diagSub.textContent = 'Fuel System Verification';
        this._setChecklist(['PASS', 'RUNNING', 'PENDING', 'PENDING']);
        UI.ignitionState.textContent = 'IGNITION';
        for (let i = 0; i < 5; i++) {
          this.audio.ignition();
          await sleep(180);
        }
        STATE.rpmTarget = 66;
        UI.rpmSlider.value = 66;
        UI.rpmPercent.textContent = '66%';
        this._setChecklist(['PASS', 'PASS', 'PENDING', 'PENDING']);
        await step(2, 'Fuel System', 'Fuel flow and combustion verified', 52, () => {
          UI.diagList && (UI.diagList.textContent = 'Fuel Pump / Injector / Combustion / Ignition');
        });

        // Step 3: Emergency system.
        UI.diagBig.textContent = 'STEP 3';
        UI.diagSub.textContent = 'Emergency System Test';
        this._setChecklist(['PASS', 'PASS', 'RUNNING', 'PENDING']);
        STATE.alarm = true;
        UI.lightEmergency.classList.remove('warn');
        UI.lightEmergency.classList.add('bad');
        UI.diagState.textContent = 'ALARM';
        this.audio.alarmPulse();
        for (let i = 0; i < 8; i++) {
          STATE.emergencyPulse = i % 2;
          await sleep(120);
        }
        this._setChecklist(['PASS', 'PASS', 'PASS', 'PENDING']);
        await step(3, 'Emergency System', 'Fire detection, suppression, and shutdown verified', 78);
        STATE.alarm = false;
        UI.lightEmergency.classList.remove('bad');
        UI.lightEmergency.classList.add('ok');

        // Step 4: Final verification.
        UI.diagBig.textContent = 'SYSTEM READY';
        UI.diagSub.textContent = 'ENGINE CERTIFIED • MISSION READY';
        this._setChecklist(['PASS', 'PASS', 'PASS', 'PASS']);
        UI.diagProgress.style.width = '100%';
        STATE.confetti = 1;
        this.confetti.points.visible = true;
        this.audio.alarmPulse();
        await sleep(700);
        STATE.confetti = 0;
        this.confetti.points.visible = false;
        UI.diagState.textContent = 'COMPLETE';
        UI.dataMode.textContent = 'NORMAL';
        this._endDiagnostics();
      }

      _endDiagnostics(forceClose = false) {
        STATE.diagRunning = false;
        STATE.diagnostics = false;
        STATE.alarm = false;
        this.hotspots.enabled = true;
        this.controls.enabled = true;
        UI.diagState.textContent = 'IDLE';
        UI.engineStatus.textContent = STATE.engineOn ? 'SPINNING' : 'STANDBY';
        UI.engineStatus.parentElement.className = `status-pill ${STATE.engineOn ? 'ok' : 'ok'}`;
        if (forceClose) UI.diagPanel.classList.remove('show');
        UI.lightEmergency.classList.add('bad');
        this._setChecklist(['PASS', 'PASS', 'PASS', 'PASS']);
      }

      _onResize() {
        this.camera.aspect = window.innerWidth / window.innerHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.composer.setSize(window.innerWidth, window.innerHeight);
        this.bloom.setSize(window.innerWidth, window.innerHeight);
      }

      _updateTopTelemetry(data) {
        const rpm = Math.round(data.rpm);
        const n1 = Math.round(data.n1);
        const n2 = Math.round(data.n2);
        const temp = Math.round(data.temperature);
        const thrust = Math.round(data.thrust / 10) / 10;
        const fps = Math.round(STATE.fps);
        UI.fpsCounter.textContent = `${fps}`;
        UI.simTime.textContent = this._formatTime(STATE.time);
        UI.tempReadout.textContent = `${temp} K`;
        UI.fuelReadout.textContent = `${data.pressure.toFixed(2)} bar`;
        UI.rpmReadout.textContent = `${rpm}%`;
        UI.thrustReadout.textContent = `${thrust} kN`;
        UI.n1Value && (UI.n1Value.textContent = `${n1}%`);
        document.getElementById('n1-value').textContent = `${n1}%`;
        document.getElementById('n2-value').textContent = `${n2}%`;
        document.getElementById('egt-value').textContent = `${Math.round(data.egt)} K`;
        document.getElementById('thrust-value').textContent = `${thrust} kN`;
        UI.fuelFlow.textContent = `${data.fuelFlow.toFixed(2)} kg/s`;
        UI.prValue.textContent = `${data.pressure.toFixed(2)}`;
        UI.oilPressure.textContent = `${data.oilPressure.toFixed(2)} bar`;
        UI.oilTemp.textContent = `${Math.round(data.oilTemp)} K`;
        UI.vibration.textContent = `${data.vibration.toFixed(2)} g`;
        UI.ignitionState.textContent = STATE.engineOn ? 'ON' : 'OFF';
        UI.engineStatus.textContent = STATE.diagnostics ? 'DIAGNOSTIC' : STATE.engineOn ? (rpm > 2 ? 'SPINNING' : 'STARTING') : 'STANDBY';
        document.getElementById('engine-lamp').textContent = STATE.diagnostics ? 'DIAG ACTIVE' : STATE.engineOn ? 'ACTIVE' : 'READY';
        UI.lightCore.className = `light ${rpm > 40 ? 'ok' : 'warn'}`;
        UI.lightFuel.className = `light ${rpm > 18 ? 'ok' : 'warn'}`;
        UI.lightVibration.className = `light ${data.vibration < 0.2 ? 'ok' : 'warn'}`;
      }

      _formatTime(sec) {
        const m = Math.floor(sec / 60);
        const s = (sec % 60).toFixed(1).padStart(4, '0');
        return `${String(m).padStart(2, '0')}:${s}`;
      }

      _updateGauges(data) {
        const mapValue = (value, max) => THREE.MathUtils.clamp(value / max, 0, 1);
        const updateGauge = (idArc, idNeedle, value, max) => {
          const arc = document.getElementById(idArc);
          const needle = document.getElementById(idNeedle);
          const c = 2 * Math.PI * 44;
          const p = mapValue(value, max);
          if (arc) arc.setAttribute('stroke-dasharray', `${p * c} ${c}`);
          if (needle) {
            const angle = -Math.PI + p * Math.PI;
            const x2 = 60 + Math.cos(angle) * 44;
            const y2 = 60 + Math.sin(angle) * 44;
            needle.setAttribute('x2', x2.toFixed(2));
            needle.setAttribute('y2', y2.toFixed(2));
          }
        };
        updateGauge('arc-n1', 'needle-n1', data.n1, 100);
        updateGauge('arc-n2', 'needle-n2', data.n2, 120);
        updateGauge('arc-egt', 'needle-egt', data.egt - 288, 980);
        updateGauge('arc-thrust', 'needle-thrust', data.thrust, 245);
      }

      _updateAutoCamera(dt, rpm01, data) {
        if (!STATE.autoCamera) return;
        STATE.cameraPulse += dt;
        const t = STATE.cameraPulse;
        const radius = 12.0 - rpm01 * 3.0;
        const x = Math.cos(t * 0.35) * radius;
        const z = Math.sin(t * 0.35) * radius + 2.0;
        const y = 2.0 + Math.sin(t * 0.75) * 1.5;
        this.camera.position.lerp(new THREE.Vector3(x, y, z), 0.02);
        this.controls.target.lerp(new THREE.Vector3(Math.sin(t * 0.22) * 0.5, 0.25 + Math.sin(t * 0.8) * 0.16, 0), 0.03);
        this.controls.update();
      }

      _update3DEffects(data, dt) {
        const rpm01 = data.target;
        this.bloom.strength = 0.55 + rpm01 * 1.25 + (STATE.diagnostics ? 0.22 : 0);
        this.bloom.radius = 0.35 + rpm01 * 0.38;
        this.bloom.threshold = 0.12 + (1 - rpm01) * 0.08;
        this.renderer.toneMappingExposure = 1.08 + rpm01 * 0.32 + (STATE.alarm ? 0.1 : 0);
        this.engine.group.traverse((o) => {
          if (o.isMesh && o.material && o.material.emissiveIntensity !== undefined) {
            if (o.userData.key === 'combustor' || o.userData.key === 'nozzle') {
              o.material.emissiveIntensity = 0.2 + rpm01 * (o.userData.key === 'combustor' ? 3.0 : 1.2);
            }
          }
        });
        this.hangarBeams.forEach((b, i) => {
          b.material.opacity = 0.05 + Math.sin(STATE.time * 0.4 + i) * 0.02 + rpm01 * 0.05;
        });
        this.rays[2].intensity = 1.2 + rpm01 * 1.3;
        this.rays[3].intensity = 0.6 + rpm01 * 1.0;
        this.rays[0].intensity = 1.25;
        this.rays[1].intensity = 1.05;
      }

      _loop = () => {
        requestAnimationFrame(this._loop);
        const now = performance.now();
        const dt = Math.min((now - STATE.now) / 1000, 0.033);
        STATE.now = now;
        STATE.time += dt;

        // FPS counter.
        STATE.fpsFrames++;
        const since = now - STATE.lastFpsSample;
        if (since >= 500) {
          STATE.fps = (STATE.fpsFrames * 1000) / since;
          STATE.lastFpsSample = now;
          STATE.fpsFrames = 0;
        }

        if (!STATE.started) {
          this._animateWelcome(now);
          this.renderer.render(this.scene, this.camera);
          return;
        }

        this.controls.enabled = !STATE.diagnostics;
        this.controls.update();

        // Update engine and particles.
        const data = this.engine.update(dt, STATE.rpmTarget);
        this._update3DEffects(data, dt);
        this.dust.update(dt, data.rpm, this.engine);
        this.fuelParticles.update(dt, data.rpm, this.engine);
        this.exhaustParticles.update(dt, data.rpm, this.engine);
        if (STATE.confetti > 0) this.confetti.update(dt, data.rpm, this.engine);

        // Enhanced exhaust motion based on power.
        this.exhaustParticles.points.position.set(0, 0, 0);
        this.fuelParticles.points.position.set(0, 0, 0);
        this.dust.points.position.set(0, 0, 0);
        this.confetti.points.position.set(0, 0, 0);
        this.fuelParticles.points.material.opacity = STATE.engineOn ? 0.65 + data.target * 0.25 : 0.0;
        this.exhaustParticles.points.material.opacity = 0.5 + data.target * 0.85;

        this.audio.update(data.rpm, STATE.diagnostics, STATE.alarm);
        this._updateAutoCamera(dt, data.target, data);
        this._updateTopTelemetry(data);
        this._updateGauges(data);

        // Diagnostics visual cues.
        if (STATE.diagnostics) {
          this.engine.group.rotation.y = Math.sin(STATE.time * 0.4) * 0.08;
          this.engine.setExploded(0.14 + 0.08 * Math.sin(STATE.time * 2));
          this.engine.setCutaway(0.78);
        } else {
          this.engine.group.rotation.y = Math.sin(STATE.time * 0.08) * 0.02;
          if (!STATE.exploded) this.engine.setExploded(0);
          if (!STATE.cutaway) this.engine.setCutaway(0.22);
        }

        // Visual flame / exhaust scaling.
        const exhaustScale = 0.9 + data.target * 0.9;
        this.engine.parts.hotGasCore.scale.set(1, 1, exhaustScale);
        this.engine.flame.scale.set(1, 1, 0.8 + data.target * 1.8);

        // Camera motion hint.
        this.engine.parts.nozzleLip.material.emissiveIntensity = 0.2 + data.glow * 2.0;
        this.engine.parts.fan.material.emissiveIntensity = 0.02 + data.glow * 0.1;

        // Ensure engine diagnostics panel values show correct step.
        if (STATE.diagRunning) {
          UI.diagProgress.style.boxShadow = '0 0 24px rgba(100,240,176,0.36)';
          if (STATE.alarm) {
            UI.diagState.textContent = 'ALARM';
            UI.diagProgress.style.background = 'linear-gradient(90deg, #ff5e63, #ffba4a)';
          }
        }

        // Subtle camera lens breathing.
        this.camera.fov = 42 + data.target * 2.0;
        this.camera.updateProjectionMatrix();

        this.composer.render();
      }

      _animateWelcome(now) {
        const t = now * 0.001;
        // Add a cinematic hangar-like motion to the welcome scene using the same scene background.
        this.scene.rotation.y = Math.sin(t * 0.12) * 0.05;
        this.scene.rotation.x = Math.sin(t * 0.08) * 0.02;
        this.hangarBeams.forEach((b, i) => {
          b.material.opacity = 0.06 + Math.sin(t * 0.5 + i) * 0.02;
          b.position.y = 4.5 + Math.sin(t * 0.7 + i) * 0.2;
        });
      }
    }

    // ----------------------------------------------------------------------
    // Welcome screen graphics: a separate canvas for a subtle animated hangar.
    // ----------------------------------------------------------------------
    class WelcomeBackdrop {
      constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.w = 0;
        this.h = 0;
        this.t = 0;
        this.particles = [];
        this._resize();
        window.addEventListener('resize', () => this._resize());
        for (let i = 0; i < 120; i++) {
          this.particles.push({
            x: Math.random(), y: Math.random(), z: Math.random(), r: 0.4 + Math.random() * 1.8,
            vx: (Math.random() - 0.5) * 0.0008,
            vy: -0.0005 - Math.random() * 0.0012
          });
        }
        requestAnimationFrame((ts) => this._loop(ts));
      }
      _resize() {
        this.w = this.canvas.width = Math.floor(window.innerWidth * Math.min(devicePixelRatio || 1, 2));
        this.h = this.canvas.height = Math.floor(window.innerHeight * Math.min(devicePixelRatio || 1, 2));
        this.canvas.style.width = '100%';
        this.canvas.style.height = '100%';
      }
      _drawEngineSilhouette(ctx, cx, cy, scale, rot) {
        ctx.save();
        ctx.translate(cx, cy);
        ctx.rotate(rot);
        ctx.scale(scale, scale);
        ctx.globalAlpha = 0.35;
        ctx.fillStyle = 'rgba(130,170,230,0.06)';
        ctx.strokeStyle = 'rgba(130, 225, 255, 0.24)';
        ctx.lineWidth = 2;
        // Engine body.
        ctx.beginPath();
        ctx.ellipse(0, 0, 310, 76, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        // Fan disk.
        ctx.beginPath();
        ctx.arc(-240, 0, 58, 0, Math.PI * 2);
        ctx.stroke();
        // Exhaust cone.
        ctx.beginPath();
        ctx.moveTo(230, -44);
        ctx.lineTo(360, 0);
        ctx.lineTo(230, 44);
        ctx.closePath();
        ctx.stroke();
        // Blade hints.
        for (let i = 0; i < 22; i++) {
          const a = (i / 22) * Math.PI * 2;
          ctx.beginPath();
          ctx.moveTo(-240 + Math.cos(a) * 12, Math.sin(a) * 12);
          ctx.lineTo(-240 + Math.cos(a) * 82, Math.sin(a) * 56);
          ctx.stroke();
        }
        ctx.restore();
      }
      _loop(ts) {
        this.t = ts * 0.001;
        const ctx = this.ctx;
        ctx.clearRect(0, 0, this.w, this.h);
        // Background gradient.
        const g = ctx.createLinearGradient(0, 0, 0, this.h);
        g.addColorStop(0, 'rgba(9, 15, 28, 1)');
        g.addColorStop(0.5, 'rgba(4, 7, 10, 1)');
        g.addColorStop(1, 'rgba(1, 2, 4, 1)');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, this.w, this.h);

        // Light beam cones.
        for (let i = 0; i < 5; i++) {
          const x = this.w * (0.18 + i * 0.18) + Math.sin(this.t * 0.2 + i) * 40;
          const y = this.h * 0.12;
          const beam = ctx.createLinearGradient(x, y, x, this.h * 0.8);
          beam.addColorStop(0, 'rgba(119, 221, 255, 0.0)');
          beam.addColorStop(0.22, 'rgba(119, 221, 255, 0.04)');
          beam.addColorStop(1, 'rgba(119, 221, 255, 0.0)');
          ctx.fillStyle = beam;
          ctx.beginPath();
          ctx.moveTo(x - 34, y);
          ctx.lineTo(x + 34, y);
          ctx.lineTo(x + 120, this.h);
          ctx.lineTo(x - 120, this.h);
          ctx.closePath();
          ctx.fill();
        }

        // Dust / particles.
        for (const p of this.particles) {
          p.y += p.vy;
          p.x += p.vx;
          if (p.y < -0.1) { p.y = 1.1; p.x = Math.random(); }
          if (p.x < -0.1) p.x = 1.1;
          if (p.x > 1.1) p.x = -0.1;
          const x = p.x * this.w;
          const y = p.y * this.h;
          ctx.fillStyle = `rgba(214, 244, 255, ${0.08 + p.z * 0.18})`;
          ctx.beginPath();
          ctx.arc(x, y, p.r * (0.6 + p.z * 0.9), 0, Math.PI * 2);
          ctx.fill();
        }

        // Rotating engine silhouette.
        this._drawEngineSilhouette(ctx, this.w * 0.5, this.h * 0.53, 1.0, this.t * 0.25);

        // Center glow.
        const rg = ctx.createRadialGradient(this.w * 0.5, this.h * 0.52, 20, this.w * 0.5, this.h * 0.52, this.h * 0.45);
        rg.addColorStop(0, 'rgba(95, 216, 255, 0.16)');
        rg.addColorStop(0.45, 'rgba(95, 216, 255, 0.06)');
        rg.addColorStop(1, 'rgba(95, 216, 255, 0)');
        ctx.fillStyle = rg;
        ctx.fillRect(0, 0, this.w, this.h);

        requestAnimationFrame((t) => this._loop(t));
      }
    }

    // Boot the application.
    const backdrop = new WelcomeBackdrop(document.getElementById('welcome-canvas'));
    const app = new SceneController();

    // Minor UI niceties.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        UI.dialogPanel.classList.remove('show');
        UI.diagPanel.classList.remove('show');
      }
      if (e.key.toLowerCase() === 'f') app._fullscreen();
      if (e.key.toLowerCase() === 'r') app._resetCamera();
      if (e.key.toLowerCase() === 'e') app._toggleExploded();
      if (e.key.toLowerCase() === 'c') app._toggleCutaway();
    });

    // Small startup hint animations.
    gsap.from('.welcome-overlay > *', { y: 16, opacity: 0, duration: 0.9, stagger: 0.08, ease: 'power3.out' });
    gsap.to('.brand-dot', { scale: 1.25, duration: 1.2, repeat: -1, yoyo: true, ease: 'sine.inOut' });

    // Expose minimal state for debugging only.
    window.__JET_ENGINE_SIM__ = { app, STATE };
  </script></body>
