      _addRing(radius, thickness, length, material, key, y = 0) {
        const geo = new THREE.CylinderGeometry(radius, radius, length, 64, 1, true);
        const mesh = new THREE.Mesh(geo, material);
        mesh.rotation.z = Math.PI / 2;
        mesh.position.y = y;
        mesh.userData.key = key;
        this.group.add(mesh);
        this.parts[key] = mesh;
        return mesh;
      }

      _addBlade(radius, width, height, material, key, count, phaseOffset = 0, pitch = 0) {
        const g = new THREE.Group();
        g.userData.key = key;
        for (let i = 0; i < count; i++) {
          const bladeGeo = new THREE.BoxGeometry(width, height, 0.12);
          bladeGeo.translate(radius * 0.55, 0, 0);
          const blade = new THREE.Mesh(bladeGeo, material);
          blade.rotation.z = (i / count) * Math.PI * 2 + phaseOffset;
          blade.rotation.y = pitch;
          blade.userData.key = key;
          g.add(blade);
        }
        this.group.add(g);
        this.parts[key] = g;
        return g;
      }

