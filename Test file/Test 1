<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="color-scheme" content="dark" />
  <title>Jet Engine Simulator</title>
  <style>
    :root {
      --bg: #07090d;
      --panel: rgba(18, 22, 30, 0.68);
      --panel-2: rgba(25, 30, 40, 0.82);
      --panel-border: rgba(160, 190, 255, 0.13);
      --text: #eff5ff;
      --muted: rgba(230, 240, 255, 0.68);
      --accent: #69d7ff;
      --accent-2: #8ea8ff;
      --danger: #ff5e63;
      --warn: #ffba4a;
      --ok: #64f0b0;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
      --radius: 22px;
      --glass: blur(16px);
      --header-h: 74px;
      --footer-h: 118px;
      --side-w: 344px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      --sans: Inter, "Segoe UI", Roboto, Arial, Helvetica, sans-serif;
    }* { box-sizing: border-box; }
html, body { margin: 0; width: 100%; height: 100%; overflow: hidden; background: radial-gradient(circle at top, #111825 0%, #06070b 55%, #020308 100%); color: var(--text); font-family: var(--sans); }
body::before {
  content: "";
  position: fixed; inset: 0;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(180deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 80px 80px;
  opacity: 0.08;
  mix-blend-mode: screen;
}

#app { position: fixed; inset: 0; overflow: hidden; }
#three-root { position: absolute; inset: 0; }
canvas { display: block; }

.screen {
  position: absolute; inset: 0;
  display: flex;
  opacity: 0;
  transform: scale(1.01);
  transition: opacity 0.7s ease, transform 0.7s ease;
  pointer-events: none;
}
.screen.active { opacity: 1; transform: scale(1); pointer-events: auto; }

/* ------------------------------------------------------------------
   Welcome / Start Screen
   ------------------------------------------------------------------ */
#welcome-screen {
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at center, rgba(58, 94, 160, 0.25) 0%, rgba(4, 6, 10, 0.82) 48%, rgba(0, 0, 0, 0.95) 100%),
    linear-gradient(180deg, #0d1320 0%, #05070b 100%);
  isolation: isolate;
}

#welcome-canvas {
  position: absolute; inset: 0; width: 100%; height: 100%;
  filter: saturate(1.2) contrast(1.04);
  opacity: 0.92;
}

.welcome-overlay {
  position: relative;
  width: min(980px, 90vw);
  padding: 40px 28px 34px;
  display: grid;
  gap: 18px;
  justify-items: center;
  text-align: center;
  z-index: 2;
}

.brand-tag {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  border: 1px solid rgba(145, 187, 255, 0.18);
  border-radius: 999px;
  background: rgba(15, 18, 25, 0.5);
  backdrop-filter: blur(12px);
  box-shadow: var(--shadow);
  color: rgba(235, 245, 255, 0.88);
  letter-spacing: 0.18em;
  font-size: 12px;
  text-transform: uppercase;
}
.brand-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: radial-gradient(circle, #dbfeff 0%, #5ee6ff 38%, rgba(94, 230, 255, 0.1) 70%);
  box-shadow: 0 0 20px rgba(86, 226, 255, 0.75);
}

.title {
  font-size: clamp(38px, 7vw, 82px);
  font-weight: 800;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  margin: 0;
  line-height: 0.95;
  text-shadow: 0 0 18px rgba(103, 214, 255, 0.35), 0 6px 28px rgba(0, 0, 0, 0.7);
}

.subtitle {
  margin: 0;
  max-width: 760px;
  font-size: clamp(14px, 1.8vw, 18px);
  color: rgba(228, 240, 255, 0.76);
  letter-spacing: 0.08em;
  text-transform: none;
  line-height: 1.55;
}

.launch-row {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-top: 10px;
  flex-wrap: wrap;
  justify-content: center;
}

.start-btn {
  position: relative;
  border: 0;
  cursor: pointer;
  color: #06111a;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 18px 30px;
  border-radius: 16px;
  background:
    linear-gradient(135deg, rgba(169, 244, 255, 1) 0%, rgba(92, 216, 255, 1) 40%, rgba(118, 158, 255, 1) 100%);
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.18) inset,
    0 14px 40px rgba(61, 194, 255, 0.28),
    0 0 36px rgba(91, 215, 255, 0.22);
  transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  overflow: hidden;
}
.start-btn:hover { transform: translateY(-2px) scale(1.02); filter: brightness(1.05); box-shadow: 0 0 0 1px rgba(255,255,255,0.18) inset, 0 18px 60px rgba(61, 194, 255, 0.38), 0 0 48px rgba(91, 215, 255, 0.4); }
.start-btn:active { transform: translateY(0px) scale(0.99); }
.start-btn::after {
  content: "";
  position: absolute; inset: -40% -30%;
  background: linear-gradient(120deg, transparent 20%, rgba(255,255,255,0.48) 50%, transparent 80%);
  transform: translateX(-120%) rotate(8deg);
  transition: transform 0.9s ease;
}
.start-btn:hover::after { transform: translateX(120%) rotate(8deg); }

.welcome-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  width: min(880px, 100%);
  margin-top: 14px;
}
.mini-card {
  padding: 14px 16px;
  border-radius: 18px;
  border: 1px solid rgba(150, 190, 255, 0.13);
  background: rgba(9, 12, 18, 0.46);
  backdrop-filter: blur(14px);
  text-align: left;
  box-shadow: var(--shadow);
}
.mini-card .k { display: block; color: rgba(233, 243, 255, 0.58); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 6px; }
.mini-card .v { font-size: 20px; font-weight: 700; color: #f3f9ff; }

.engine-mini-label {
  margin-top: 8px;
  display: inline-flex;
  gap: 12px;
  color: rgba(240,248,255,0.66);
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  align-items: center;
}

/* ------------------------------------------------------------------
   Main Simulation Layout
   ------------------------------------------------------------------ */
#main-screen { background: linear-gradient(180deg, rgba(4,7,11,1) 0%, rgba(5,8,13,1) 100%); }

#ui {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-rows: var(--header-h) 1fr var(--footer-h);
  pointer-events: none;
}

.topbar, .footer {
  pointer-events: auto;
  margin: 14px;
  border: 1px solid var(--panel-border);
  background: linear-gradient(180deg, rgba(31, 36, 48, 0.76) 0%, rgba(11, 14, 20, 0.74) 100%);
  backdrop-filter: var(--glass);
  box-shadow: var(--shadow);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  position: relative;
  overflow: hidden;
}
.topbar::before, .footer::before {
  content: "";
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(102, 183, 255, 0.08), transparent 30%, rgba(255,255,255,0.02) 70%, rgba(102,183,255,0.06));
  pointer-events: none;
}

.topbar { justify-content: space-between; }

.brand-block {
  display: flex; align-items: center; gap: 14px;
  min-width: 270px;
}
.brand-lockup {
  width: 42px; height: 42px; border-radius: 14px;
  background: radial-gradient(circle at 30% 30%, #7fe8ff 0%, #376a92 30%, #0d121a 78%);
  box-shadow: 0 0 0 1px rgba(180, 220, 255, 0.16) inset, 0 0 20px rgba(79, 204, 255, 0.2);
  position: relative;
  overflow: hidden;
}
.brand-lockup::after {
  content: "";
  position: absolute; inset: 11px;
  border: 2px solid rgba(220, 244, 255, 0.7);
  border-left-color: transparent;
  border-radius: 999px;
  transform: rotate(10deg);
}
.brand-meta { display: grid; }
.brand-meta strong { font-size: 16px; letter-spacing: 0.08em; text-transform: uppercase; }
.brand-meta span { font-size: 11px; color: rgba(231, 241, 255, 0.62); letter-spacing: 0.12em; text-transform: uppercase; }

.status-grid {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.status-pill {
  min-width: 92px;
  padding: 9px 12px;
  border-radius: 999px;
  border: 1px solid rgba(157, 195, 255, 0.16);
  background: rgba(8, 10, 15, 0.5);
  display: grid;
  gap: 3px;
  text-align: center;
  line-height: 1.1;
}
.status-pill .label { font-size: 9px; text-transform: uppercase; color: rgba(227,239,255,0.54); letter-spacing: 0.16em; }
.status-pill .value { font-family: var(--mono); font-size: 14px; font-weight: 700; }
.status-pill.ok .value { color: var(--ok); }
.status-pill.warn .value { color: var(--warn); }
.status-pill.alert .value { color: var(--danger); }

.header-tools {
  display: flex; align-items: center; gap: 10px;
  margin-left: auto;
}
.tool-btn {
  pointer-events: auto;
  border: 1px solid rgba(159, 198, 255, 0.16);
  background: linear-gradient(180deg, rgba(43, 50, 66, 0.95), rgba(17, 20, 28, 0.95));
  color: var(--text);
  border-radius: 14px;
  padding: 11px 14px;
  font-size: 12px;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  cursor: pointer;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  white-space: nowrap;
}
.tool-btn:hover { transform: translateY(-1px); border-color: rgba(121, 208, 255, 0.38); }
.tool-btn.primary {
  background: linear-gradient(135deg, rgba(46, 97, 136, 0.95), rgba(17, 67, 101, 0.95));
  border-color: rgba(112, 223, 255, 0.25);
}

.workspace {
  display: grid;
  grid-template-columns: var(--side-w) 1fr 340px;
  gap: 16px;
  min-height: 0;
  padding: 0 14px;
}

.panel {
  pointer-events: auto;
  border: 1px solid rgba(151, 190, 255, 0.13);
  background: linear-gradient(180deg, rgba(18, 23, 32, 0.88), rgba(8, 11, 17, 0.88));
  border-radius: 22px;
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow);
  overflow: hidden;
  position: relative;
  min-height: 0;
}
.panel::before {
  content: "";
  position: absolute; inset: 0;
  background: linear-gradient(130deg, rgba(105, 215, 255, 0.06), transparent 28%, transparent 75%, rgba(255,255,255,0.02));
  pointer-events: none;
}
.panel-header {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(175, 205, 255, 0.1);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent);
}
.panel-title {
  font-size: 12px; text-transform: uppercase; letter-spacing: 0.17em; color: rgba(233, 241, 255, 0.85);
}
.panel-subtitle { font-size: 11px; color: rgba(223, 235, 255, 0.55); letter-spacing: 0.08em; }
.panel-body { padding: 16px; height: calc(100% - 54px); overflow: auto; }

#canvas-wrap {
  position: relative;
  min-height: 0;
  overflow: hidden;
  border-radius: 26px;
  border: 1px solid rgba(150, 188, 255, 0.12);
  box-shadow: var(--shadow);
  background:
    radial-gradient(circle at 50% 40%, rgba(70, 126, 179, 0.14) 0%, rgba(7, 10, 16, 0.15) 45%, rgba(0,0,0,0.28) 100%),
    linear-gradient(180deg, rgba(8,10,14,0.5), rgba(2,3,5,0.8));
}

#three-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  outline: none;
}

#hud-left, #hud-right {
  display: grid;
  gap: 14px;
  align-content: start;
}

.gauge-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}
.gauge-card {
  padding: 12px;
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
  border: 1px solid rgba(148, 191, 255, 0.12);
  min-height: 126px;
  position: relative;
  overflow: hidden;
}
.gauge-card .label { font-size: 10px; letter-spacing: 0.15em; color: rgba(226, 238, 255, 0.62); text-transform: uppercase; margin-bottom: 8px; }
.gauge-card .value { font-family: var(--mono); font-size: 22px; font-weight: 800; }
.gauge-card .unit { font-size: 11px; color: rgba(227,237,255,0.58); }
.gauge-svg { width: 100%; height: 78px; display: block; margin-top: 4px; overflow: visible; }
.gauge-track { stroke: rgba(255,255,255,0.08); stroke-width: 8; fill: none; stroke-linecap: round; }
.gauge-arc { stroke: url(#gaugeGradient); stroke-width: 8; fill: none; stroke-linecap: round; filter: drop-shadow(0 0 10px rgba(105,215,255,0.5)); }
.gauge-needle { stroke: rgba(255,255,255,0.85); stroke-width: 2; stroke-linecap: round; }

.info-card {
  padding: 14px;
  border-radius: 18px;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(151, 189, 255, 0.11);
  display: grid;
  gap: 10px;
}
.info-card h3, .info-card h4 { margin: 0; }
.info-card h3 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.14em; }
.info-card p { margin: 0; color: rgba(229, 239, 255, 0.72); line-height: 1.5; font-size: 13px; }
.info-list {
  display: grid;
  gap: 9px;
}
.info-row {
  display: flex; justify-content: space-between; gap: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  font-size: 12px;
}
.info-row span:first-child { color: rgba(223,235,255,0.56); }
.info-row span:last-child { font-family: var(--mono); color: #f1f7ff; text-align: right; }

.status-lights { display: flex; gap: 10px; flex-wrap: wrap; }
.light { display: inline-flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 999px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); }
.light-dot { width: 10px; height: 10px; border-radius: 50%; background: #667; box-shadow: 0 0 0 rgba(0,0,0,0); }
.light.ok .light-dot { background: var(--ok); box-shadow: 0 0 14px rgba(100,240,176,0.82); }
.light.warn .light-dot { background: var(--warn); box-shadow: 0 0 14px rgba(255,186,74,0.82); }
.light.bad .light-dot { background: var(--danger); box-shadow: 0 0 14px rgba(255,94,99,0.82); }
.light span:last-child { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(234, 243, 255, 0.76); }

.footer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 270px 230px;
  gap: 16px;
  align-items: center;
  padding-right: 16px;
}

.control-group { display: grid; gap: 8px; }
.control-label { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em; color: rgba(232,241,255,0.62); }
.control-label b { font-family: var(--mono); color: #fff; font-size: 12px; }
input[type="range"] {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  height: 10px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(102, 219, 255, 0.9), rgba(120, 154, 255, 0.85));
  outline: none;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08), 0 8px 30px rgba(80,180,255,0.14);
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 26px; height: 26px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #f6fbff 0%, #afedff 20%, #5fd9ff 55%, #2d6d9e 100%);
  border: 1px solid rgba(255,255,255,0.3);
  box-shadow: 0 0 0 5px rgba(98, 213, 255, 0.12), 0 0 22px rgba(97, 214, 255, 0.55);
  cursor: pointer;
}
.toggle-row {
  display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end;
}
.toggle-row .tool-btn { padding: 12px 13px; }

.sidebar-stack { display: grid; gap: 14px; min-height: 0; }

.mini-table {
  width: 100%; border-collapse: collapse; font-size: 12px;
}
.mini-table td {
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 9px 0;
  vertical-align: top;
}
.mini-table td:first-child { color: rgba(224, 236, 255, 0.58); width: 48%; }
.mini-table td:last-child { color: #fff; font-family: var(--mono); text-align: right; }

.checklist {
  display: grid;
  gap: 10px;
}
.check-item {
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  padding: 10px 12px;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px;
  font-size: 12px;
}
.check-item .status { font-family: var(--mono); color: var(--warn); }
.check-item.pass .status { color: var(--ok); }
.check-item.fail .status { color: var(--danger); }

.tooltip {
  position: fixed;
  pointer-events: none;
  z-index: 50;
  padding: 10px 12px;
  max-width: 260px;
  border-radius: 14px;
  background: rgba(6, 10, 16, 0.9);
  border: 1px solid rgba(130, 195, 255, 0.16);
  color: #f4f8ff;
  box-shadow: var(--shadow);
  backdrop-filter: blur(16px);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.14s ease, transform 0.14s ease;
  font-size: 12px;
  line-height: 1.45;
}
.tooltip.show { opacity: 1; transform: translateY(0); }
.tooltip .t { display: block; font-weight: 700; margin-bottom: 4px; letter-spacing: 0.08em; text-transform: uppercase; }
.tooltip .d { color: rgba(233,241,255,0.72); }

#diag-panel {
  position: absolute;
  right: 18px;
  top: 90px;
  width: min(400px, calc(100vw - 36px));
  max-height: calc(100vh - 200px);
  overflow: auto;
  opacity: 0;
  pointer-events: none;
  transform: translateX(22px);
  transition: opacity 0.35s ease, transform 0.35s ease;
  z-index: 20;
}
#diag-panel.show { opacity: 1; transform: translateX(0); pointer-events: auto; }
.diag-banner {
  padding: 16px;
  border-radius: 18px;
  border: 1px solid rgba(112, 223, 255, 0.2);
  background: linear-gradient(180deg, rgba(18, 29, 44, 0.92), rgba(7, 10, 16, 0.92));
  box-shadow: var(--shadow);
}
.diag-banner h2 { margin: 0 0 6px; font-size: 14px; letter-spacing: 0.16em; text-transform: uppercase; }
.diag-banner .big { font-size: 28px; font-weight: 800; letter-spacing: 0.14em; margin: 8px 0 6px; }
.diag-banner .sub { font-size: 12px; color: rgba(232,242,255,0.68); line-height: 1.45; }

.progress-shell { margin-top: 12px; height: 10px; border-radius: 999px; background: rgba(255,255,255,0.07); overflow: hidden; }
.progress-fill { height: 100%; width: 0%; background: linear-gradient(90deg, #64f0b0, #66dbff, #8ea8ff); box-shadow: 0 0 20px rgba(100,240,176,0.3); }

#dialog-panel {
  position: absolute;
  left: 50%; top: 110px;
  transform: translateX(-50%);
  width: min(620px, calc(100vw - 28px));
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  z-index: 22;
}
#dialog-panel.show { opacity: 1; pointer-events: auto; }
.dialog {
  border-radius: 20px;
  padding: 18px;
  background: linear-gradient(180deg, rgba(18,22,30,0.96), rgba(8,10,15,0.96));
  border: 1px solid rgba(150, 190, 255, 0.16);
  box-shadow: var(--shadow);
}
.dialog h3 { margin: 0 0 8px; font-size: 15px; letter-spacing: 0.16em; text-transform: uppercase; }
.dialog p { margin: 0 0 8px; color: rgba(233,240,255,0.72); line-height: 1.56; }
.dialog .close { float: right; }

.hidden { display: none !important; }

@media (max-width: 1200px) {
  :root { --side-w: 300px; }
  .workspace { grid-template-columns: 300px 1fr 310px; }
  .footer { grid-template-columns: 1fr; height: auto; }
  #ui { grid-template-rows: var(--header-h) 1fr auto; }
}

@media (max-width: 980px) {
  :root { --header-h: 88px; --footer-h: 152px; }
  .topbar { flex-wrap: wrap; align-items: stretch; }
  .brand-block { min-width: 0; }
  .header-tools { flex-wrap: wrap; }
  .workspace { grid-template-columns: 1fr; grid-template-rows: 220px minmax(300px, 1fr) auto; }
  #hud-left, #hud-right { grid-template-columns: 1fr; }
  .sidebar-stack { grid-template-columns: 1fr; }
  #diag-panel { top: 120px; }
}

@media (max-width: 640px) {
  .welcome-overlay { width: min(96vw, 100%); padding: 20px 10px; }
  .welcome-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .title { letter-spacing: 0.08em; }
  .topbar, .footer { margin: 10px; padding: 12px; }
  .status-pill { min-width: 72px; }
  .tool-btn { font-size: 11px; padding: 10px 11px; }
  .workspace { padding: 0 10px; gap: 10px; }
  #diag-panel, #dialog-panel { width: calc(100vw - 20px); }
}

  </style>
</head>
<body>
  <div id="app">
    <div id="three-root"></div><!-- WELCOME SCREEN -->
<section id="welcome-screen" class="screen active" aria-label="Welcome Screen">
