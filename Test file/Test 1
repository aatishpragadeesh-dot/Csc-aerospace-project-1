    class AudioEngine {
      constructor() {
        this.ctx = null;
        this.master = null;
        this.noiseNode = null;
        this.oscIdle = null;
        this.oscSpool = null;
        this.oscTurbine = null;
        this.gainIdle = null;
        this.gainSpool = null;
        this.gainTurbine = null;
        this.alarmGain = null;
        this.windGain = null;
        this.wind = null;
        this.initialized = false;
      }

      init() {
        if (this.initialized) return;
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return;
        this.ctx = new AC();
        this.master = this.ctx.createGain();
        this.master.gain.value = 0.18;
        this.master.connect(this.ctx.destination);

        this.gainIdle = this.ctx.createGain();
        this.gainSpool = this.ctx.createGain();
        this.gainTurbine = this.ctx.createGain();
        this.alarmGain = this.ctx.createGain();
        this.windGain = this.ctx.createGain();
        this.gainIdle.connect(this.master);
        this.gainSpool.connect(this.master);
        this.gainTurbine.connect(this.master);
        this.alarmGain.connect(this.master);
        this.windGain.connect(this.master);

        this.oscIdle = this.ctx.createOscillator();
        this.oscSpool = this.ctx.createOscillator();
        this.oscTurbine = this.ctx.createOscillator();
        this.oscIdle.type = 'sine';
        this.oscSpool.type = 'sawtooth';
        this.oscTurbine.type = 'triangle';
        this.oscIdle.frequency.value = 48;
        this.oscSpool.frequency.value = 70;
        this.oscTurbine.frequency.value = 92;
        this.oscIdle.connect(this.gainIdle);
        this.oscSpool.connect(this.gainSpool);
        this.oscTurbine.connect(this.gainTurbine);
        this.oscIdle.start();
        this.oscSpool.start();
        this.oscTurbine.start();

        // Wind / fan noise using buffer source noise loop.
        const buffer = this.ctx.createBuffer(1, this.ctx.sampleRate * 2, this.ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * 0.18;
        this.noiseNode = this.ctx.createBufferSource();
        this.noiseNode.buffer = buffer;
        this.noiseNode.loop = true;
        const filter = this.ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.value = 460;
        filter.Q.value = 0.5;
        this.noiseNode.connect(filter);
        filter.connect(this.windGain);
        this.noiseNode.start();

        this.initialized = true;
      }

