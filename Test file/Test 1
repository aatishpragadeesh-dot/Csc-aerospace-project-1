        if (!this.initialized) return;
        const t = THREE.MathUtils.clamp(rpm / 100, 0, 1);
        const idle = Math.max(0, 1 - t * 2.0);
        const spool = Math.pow(t, 0.75);
        const turbine = Math.pow(t, 1.25);
        const wind = Math.pow(t, 1.1);

        this.oscIdle.frequency.setTargetAtTime(40 + t * 30, this.ctx.currentTime, 0.05);
        this.oscSpool.frequency.setTargetAtTime(60 + t * 300, this.ctx.currentTime, 0.05);
        this.oscTurbine.frequency.setTargetAtTime(90 + t * 520, this.ctx.currentTime, 0.05);

        this.gainIdle.gain.setTargetAtTime((0.07 + idle * 0.08) * (diagActive ? 0.25 : 1), this.ctx.currentTime, 0.04);
        this.gainSpool.gain.setTargetAtTime(0.03 + spool * 0.11, this.ctx.currentTime, 0.04);
        this.gainTurbine.gain.setTargetAtTime(0.02 + turbine * 0.10, this.ctx.currentTime, 0.04);
        this.windGain.gain.setTargetAtTime(0.02 + wind * 0.12, this.ctx.currentTime, 0.05);

        this.alarmGain.gain.setTargetAtTime(alarm ? 0.18 : 0.0, this.ctx.currentTime, 0.02);
        if (alarm) {
          if (!this.wind) {
            this.wind = this.ctx.createOscillator();
            const g = this.ctx.createGain();
            const f = this.ctx.createBiquadFilter();
            f.type = 'highpass';
            f.frequency.value = 1800;
            this.wind.type = 'square';
            this.wind.frequency.value = 32;
            this.wind.connect(f); f.connect(g); g.connect(this.alarmGain);
            this.wind.start();
            this.wind._g = g;
          }
          this.wind.frequency.setTargetAtTime(28 + Math.sin(performance.now() * 0.012) * 4, this.ctx.currentTime, 0.02);
          this.wind._g.gain.setTargetAtTime(0.8, this.ctx.currentTime, 0.02);
        } else if (this.wind) {
          this.wind._g.gain.setTargetAtTime(0.0, this.ctx.currentTime, 0.04);
        }
      }

      click() {
        if (!this.initialized) return;
        const osc = this.ctx.createOscillator();
        const g = this.ctx.createGain();
        osc.type = 'triangle';
        osc.frequency.value = 250;
        g.gain.value = 0.05;
        osc.connect(g); g.connect(this.master);
        osc.start();
        osc.frequency.exponentialRampToValueAtTime(100, this.ctx.currentTime + 0.08);
        g.gain.exponentialRampToValueAtTime(0.0001, this.ctx.currentTime + 0.12);
        osc.stop(this.ctx.currentTime + 0.13);
      }

      ignition() {
        if (!this.initialized) return;
        const osc = this.ctx.createOscillator();
        const g = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.value = 620;
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(90, this.ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(240, this.ctx.currentTime + 0.25);
        g.gain.value = 0.001;
        osc.connect(filter); filter.connect(g); g.connect(this.master);
        osc.start();
        g.gain.exponentialRampToValueAtTime(0.09, this.ctx.currentTime + 0.05);
        g.gain.exponentialRampToValueAtTime(0.0001, this.ctx.currentTime + 0.5);
        osc.stop(this.ctx.currentTime + 0.55);
      }

      alarmPulse() {
        if (!this.initialized) return;
        const osc = this.ctx.createOscillator();
        const g = this.ctx.createGain();
        osc.type = 'square';
        osc.frequency.value = 880;
        g.gain.value = 0.0001;
        osc.connect(g); g.connect(this.master);
        osc.start();
        g.gain.exponentialRampToValueAtTime(0.12, this.ctx.currentTime + 0.03);
        g.gain.exponentialRampToValueAtTime(0.0001, this.ctx.currentTime + 0.16);
        osc.stop(this.ctx.currentTime + 0.18);
      }
    }

    class ParticleField {
      constructor(scene, count, type = 'dust') {
        this.scene = scene;
        this.count = count;
        this.type = type;
        this.geometry = new THREE.BufferGeometry();
        this.positions = new Float32Array(count * 3);
        this.velocities = new Float32Array(count * 3);
        this.base = new Float32Array(count);
        this.seed = new Float32Array(count);
        this._init();
      }

      _init() {
        for (let i = 0; i < this.count; i++) {
          const i3 = i * 3;
          const r = 4 + Math.random() * 22;
          const a = Math.random() * Math.PI * 2;
          const y = (Math.random() - 0.5) * 18;
          this.positions[i3] = Math.cos(a) * r;
          this.positions[i3 + 1] = y;
          this.positions[i3 + 2] = Math.sin(a) * r;
          this.velocities[i3] = (Math.random() - 0.5) * 0.01;
          this.velocities[i3 + 1] = 0.005 + Math.random() * 0.02;
          this.velocities[i3 + 2] = (Math.random() - 0.5) * 0.01;
          this.base[i] = Math.random();
          this.seed[i] = Math.random() * 10;
        }
        this.geometry.setAttribute('position', new THREE.BufferAttribute(this.positions, 3));
        const material = new THREE.PointsMaterial({
          size: this.type === 'fuel' ? 0.08 : this.type === 'exhaust' ? 0.12 : 0.06,
          transparent: true,
          opacity: 0.8,
          depthWrite: false,
          blending: THREE.AdditiveBlending,
          color: this.type === 'fuel' ? 0x7cf5ff : this.type === 'exhaust' ? 0x84b9ff : 0xffffff
        });
        this.points = new THREE.Points(this.geometry, material);
        this.points.frustumCulled = false;
        this.scene.add(this.points);
      }

      update(dt, rpm, engine) {
        const pos = this.positions;
        const t = rpm / 100;
        for (let i = 0; i < this.count; i++) {
          const i3 = i * 3;
          const s = this.seed[i];
          if (this.type === 'dust') {
            pos[i3] += Math.sin(engine.time * 0.18 + s) * 0.002 + this.velocities[i3] * 0.3;
            pos[i3 + 1] += Math.cos(engine.time * 0.15 + s) * 0.001;
            pos[i3 + 2] += Math.cos(engine.time * 0.12 + s) * 0.002 + this.velocities[i3 + 2] * 0.3;
            if (pos[i3 + 1] > 15) pos[i3 + 1] = -15;
          } else if (this.type === 'fuel') {
            pos[i3] = -0.9 + Math.sin(engine.time * 6 + s) * 0.03;
            pos[i3 + 1] = 0.7 + Math.sin(engine.time * 8 + s) * 0.15;
            pos[i3 + 2] = -2.9 + ((engine.fuelPhase + s * 0.01) % 2.6);
            if (pos[i3 + 2] > 0.2) pos[i3 + 2] = -2.9;
          } else if (this.type === 'exhaust') {
            pos[i3] = (Math.sin(s + engine.time * 4) * 0.4) * (1 + t * 0.3);
            pos[i3 + 1] = -0.7 + Math.sin(engine.time * 7 + s) * 0.1;
            pos[i3 + 2] = 2.35 + ((engine.exhaustPhase + s) % 4.0);
            if (pos[i3 + 2] > 7.5) pos[i3 + 2] = 2.35;
          } else if (this.type === 'confetti') {
            pos[i3] += this.velocities[i3];
            pos[i3 + 1] += this.velocities[i3 + 1];
            pos[i3 + 2] += this.velocities[i3 + 2];
            this.velocities[i3 + 1] -= 0.0002;
            if (pos[i3 + 1] < -12) pos[i3 + 1] = 8 + Math.random() * 8;
          }
        }
        this.geometry.attributes.position.needsUpdate = true;
        const opacity = this.type === 'dust' ? 0.35 : this.type === 'fuel' ? 0.8 : this.type === 'exhaust' ? 0.95 : 1;
        this.points.material.opacity = opacity * (0.4 + t * 0.9);
      }
    }

    class HotspotManager {
      constructor(scene, camera, dom, onHover, onSelect) {
        this.scene = scene;
        this.camera = camera;
        this.dom = dom;
        this.onHover = onHover;
        this.onSelect = onSelect;
        this.raycaster = new THREE.Raycaster();
        this.mouse = new THREE.Vector2();
        this.hotspots = [];
        this.enabled = true;
        this.hovered = null;

        dom.addEventListener('pointermove', (e) => this._move(e));
        dom.addEventListener('pointerdown', (e) => this._down(e));
        dom.addEventListener('pointerleave', () => this._clear());
      }

      add(mesh, key, name) {
        this.hotspots.push({ mesh, key, name });
        mesh.userData.key = key;
        mesh.userData.name = name;
      }

      _move(e) {
        if (!this.enabled) return;
        const rect = this.dom.getBoundingClientRect();
        this.mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
        this.mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
        this.raycaster.setFromCamera(this.mouse, this.camera);
        const meshes = this.hotspots.map(h => h.mesh);
        const hits = this.raycaster.intersectObjects(meshes, true);
        if (hits.length) {
          const obj = hits[0].object;
          const key = obj.userData.key || obj.parent?.userData.key;
          const hotspot = this.hotspots.find(h => h.key === key);
          if (hotspot) {
            this.hovered = hotspot.key;
            this.onHover?.(hotspot, e.clientX, e.clientY);
            return;
          }
        }
        this._clear();
      }

      _down(e) {
        if (!this.enabled) return;
        const rect = this.dom.getBoundingClientRect();
        this.mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
        this.mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
        this.raycaster.setFromCamera(this.mouse, this.camera);
        const meshes = this.hotspots.map(h => h.mesh);
        const hits = this.raycaster.intersectObjects(meshes, true);
        if (hits.length) {
          const obj = hits[0].object;
          const key = obj.userData.key || obj.parent?.userData.key;
          const hotspot = this.hotspots.find(h => h.key === key);
          if (hotspot) this.onSelect?.(hotspot, e.clientX, e.clientY);
        }
      }

      _clear() {
        this.hovered = null;
        UI.tooltip.classList.remove('show');
      }
    }

